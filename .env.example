# Copy this file to .env and fill in real values from your TikTok For Business sandbox.
# .env is gitignored — never commit real credentials.

# Required to actually call the TikTok Events API.
# Get this from: TikTok Business → Apps → your app → Access Token
TIKTOK_ACCESS_TOKEN=

# The pixel code for the website you're tracking.
# Get this from: TikTok Events Manager → Web Events → your pixel → Settings
TIKTOK_PIXEL_ID=

# Test event code routes events to the "Test Events" tab in Events Manager
# instead of the live production stream. Use this during development so you
# don't pollute real attribution data. Get it from:
# TikTok Events Manager → your pixel → Test Events tab → "Test Event Code"
TIKTOK_TEST_EVENT_CODE=
